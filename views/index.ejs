<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AgriLinkHub - Connecting Agriculture</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <div class="container">
    <section class="hero" id="home">
      <div class="hero-copy">
        <span class="eyebrow">AgriLinkHub</span>
        <h1>Simplifying farming through digital agriculture solutions</h1>
        <p>Empower farmers, suppliers, and buyers with seamless access to inputs, advisory services, farm records, and market linkages.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/services">Explore Solutions</a>
          <a class="btn btn-secondary" href="/contact">Contact Us</a>
        </div>
      </div>
    </section>

    <section class="feature-highlight">
      <div class="highlight-copy">
        <h2>Enjoy end-to-end farmer solutions</h2>
        <p>From planning and inputs to production and market access, AgriLinkHub supports every stage of the farming cycle.</p>
      </div>
    </section>

    <section class="why-us">
      <h2>Why AgriLinkHub?</h2>
      <div class="feature-grid">
        <div class="feature">
          <h3>Trusted suppliers</h3>
          <p>Work with reliable partners who deliver quality agricultural inputs.</p>
        </div>
        <div class="feature">
          <h3>Data-driven decisions</h3>
          <p>Use farm analytics to make smarter decisions and reduce risk.</p>
        </div>
        <div class="feature">
          <h3>Fast market access</h3>
          <p>Reach buyers quickly and get fair prices for your produce.</p>
        </div>
        <div class="feature">
          <h3>Community support</h3>
          <p>Build relationships with farmers, advisors, and agricultural experts.</p>
        </div>
      </div>
    </section>
  </div>
  <%- include('partials/footer') %>
</body>
</html>