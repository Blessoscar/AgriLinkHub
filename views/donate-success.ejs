<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Donation Interest Submitted - AgriLinkHub</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <div class="container">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="eyebrow">Thank You</span>
        <h1>Your donation interest has been received</h1>
        <p>Thank you, <strong><%= name %></strong>. We have received your interest in supporting <strong><%= donationType.replace(/_/g, ' ') %></strong> with an estimated amount of <strong><%= amount %></strong>.</p>
        <p>Our team will contact you soon at <strong><%= email %></strong> or <strong><%= phone %></strong> to confirm the next steps.</p>
        <p><strong>Message note:</strong> <%= message ? message : 'No additional message provided.' %></p>
        <a class="btn btn-primary" href="/">Back to homepage</a>
      </div>
    </section>
  </div>
  <%- include('partials/footer') %>
</body>
</html>